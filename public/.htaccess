# Axon Careers — SPA routing for Apache / LiteSpeed (Hostinger).
# Serve real files/folders (assets, enroll.php, etc.) as-is; send every other
# path to index.html so client-side routes (e.g. /ahpra-application) resolve.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't touch existing files or directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>
